{
  "name": "argus-claude",
  "displayName": "Argus - Claude Code Agent Monitoring & Observability on VSCode",
  "description": "Monitoring and observability for Claude Code agent sessions inside VS Code — live transcripts, cost telemetry, context-window metrics, dependency graphs, and rule-based analysis of tool calls, retry loops, and compaction events.",
  "version": "0.2.0",
  "publisher": "argus-claude",
  "author": {
    "name": "Ozgur Kurucan",
    "email": "ozgurkurucan337@gmail.com"
  },
  "license": "MIT",
  "icon": "icon-128.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "Data Science",
    "Other"
  ],
  "keywords": [
    "argus",
    "claude",
    "claude-code",
    "claude code",
    "anthropic",
    "agent",
    "ai-agent",
    "agent-monitoring",
    "agent-observability",
    "observability",
    "monitoring",
    "telemetry",
    "tracing",
    "llm",
    "llm-observability",
    "llm-monitoring",
    "session-analysis",
    "session-debugger",
    "transcript",
    "jsonl",
    "tool-calls",
    "subagent",
    "cost-tracking",
    "token-usage",
    "context-window",
    "cache-hit-ratio",
    "performance",
    "analytics",
    "dashboard",
    "developer-tools",
    "vscode-extension"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yessGlory17/argus.git"
  },
  "bugs": {
    "url": "https://github.com/yessGlory17/argus/issues"
  },
  "homepage": "https://github.com/yessGlory17/argus#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "argus",
          "title": "Argus",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "argus": [
        {
          "id": "argusSessionList",
          "name": "Sessions",
          "type": "webview",
          "contextualTitle": "Claude Code Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "argus.refreshSessions",
        "title": "Refresh Sessions",
        "icon": "$(refresh)",
        "category": "Argus"
      },
      {
        "command": "argus.openSessionDetail",
        "title": "Open Session Detail",
        "category": "Argus"
      },
      {
        "command": "argus.openSessionTab",
        "title": "Open Session Tab",
        "category": "Argus"
      },
      {
        "command": "argus.clearFilters",
        "title": "Clear All Filters",
        "icon": "$(clear-all)",
        "category": "Argus"
      },
      {
        "command": "argus.toggleModelOpus",
        "title": "Toggle Opus Filter",
        "category": "Argus"
      },
      {
        "command": "argus.toggleModelSonnet",
        "title": "Toggle Sonnet Filter",
        "category": "Argus"
      },
      {
        "command": "argus.toggleModelHaiku",
        "title": "Toggle Haiku Filter",
        "category": "Argus"
      },
      {
        "command": "argus.setDateAll",
        "title": "All Time",
        "category": "Argus"
      },
      {
        "command": "argus.setDate1h",
        "title": "Last 1 Hour",
        "category": "Argus"
      },
      {
        "command": "argus.setDate24h",
        "title": "Last 24 Hours",
        "category": "Argus"
      },
      {
        "command": "argus.setDate7d",
        "title": "Last 7 Days",
        "category": "Argus"
      },
      {
        "command": "argus.setDate30d",
        "title": "Last 30 Days",
        "category": "Argus"
      },
      {
        "command": "argus.setDateCustom",
        "title": "Custom Range...",
        "category": "Argus"
      },
      {
        "command": "argus.setGroupNone",
        "title": "Flat List",
        "category": "Argus"
      },
      {
        "command": "argus.setGroupProject",
        "title": "Group by Project",
        "category": "Argus"
      },
      {
        "command": "argus.setGroupModel",
        "title": "Group by Model",
        "category": "Argus"
      }
    ],
    "submenus": [
      {
        "id": "argus.groupMenu",
        "label": "Group Sessions",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "submenu": "argus.groupMenu",
          "when": "view == argusSessionList",
          "group": "navigation@1"
        },
        {
          "command": "argus.clearFilters",
          "when": "view == argusSessionList && argus.hasActiveFilters",
          "group": "navigation@2"
        },
        {
          "command": "argus.refreshSessions",
          "when": "view == argusSessionList",
          "group": "navigation@3"
        }
      ],
      "argus.groupMenu": [
        {
          "command": "argus.setGroupNone",
          "group": "group@1"
        },
        {
          "command": "argus.setGroupProject",
          "group": "group@2"
        },
        {
          "command": "argus.setGroupModel",
          "group": "group@3"
        }
      ]
    },
    "configuration": {
      "title": "Argus",
      "properties": {
        "argus.scanDepth": {
          "type": "number",
          "default": 5,
          "description": "Maximum directory depth for scanning .claude directories"
        },
        "argus.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "tr"
          ],
          "description": "Language for analysis findings"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "vite build",
    "dev:webview": "vite",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0"
  }
}
